      "promptTriggers": {
        "keywords": ["frontend", "react", "component", "page", "api integration", "playwright", "e2e test", "typescript", "tailwind", "redux", "router", "react-router", "route config", "protected route", "RBAC", "auth guard", "guest guard", "role guard", "protected layout", "route access", "declarative routing", "framework mode"],
