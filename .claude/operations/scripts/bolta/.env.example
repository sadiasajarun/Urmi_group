# Bolta API credentials — copy to .env and fill in.
# .env is gitignored — never commit real values.
#
# Where to get these (see README.md → Team Onboarding):
#   1. Ask the team lead or retrieve from the company password vault
#   2. Or log into https://bolta.io → Developer Center (requires workspace access)
#
# The API key determines the mode:
#   test_xxx → sandbox, no 국세청 submission, no points charged
#   live_xxx → real 국세청 submission, points deducted per issuance
#
# API key and Customer key must match environments — a test API key will reject a live Customer key and vice versa.

BOLTA_API_KEY=test_replace_me
BOLTA_CUSTOMER_KEY=CustomerKey_replace_me
