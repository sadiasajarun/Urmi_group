# DUNS Registration values — copy to .env and fill in.
# .env is gitignored — never commit real values.
#
# 1Password is the source of truth. Use `npm run check` / `npm run flow`
# instead of a plaintext .env whenever possible.

DUNS_COMPANY_NAME_EN=replace_me
DUNS_COMPANY_NAME_KO=replace_me
DUNS_REPRESENTATIVE=replace_me
DUNS_BUSINESS_REGISTRATION_NUMBER=replace_me
DUNS_ADDRESS_EN=replace_me
DUNS_PHONE=replace_me
DUNS_EMAIL=replace_me
DUNS_BUSINESS_CERT_PATH=replace_me
